{
  "name": "metadata",
  "version": "1.0.0",
  "description": "Modular metadata management system",
  "scripts": {
    "start": "node --import ./dist/modules/import.js ./dist/main.js",
    "prebuild": "npx mod init",
    "build": "tsc -b tsconfig.build.json",
    "postbuild": "npx mod build",
    "dev": "node --watch --env-file .env --import ./src/modules/import.ts ./src/main.ts",
    "test": "node --test"
  },
  "bin": {
    "mod": "./scripts/mod.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "24.14.1"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "find-my-way": "9.5.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "typescript": "6.0.2"
  }
}
